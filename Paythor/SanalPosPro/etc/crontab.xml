<?xml version="1.0"?>
<!--
/**
 * File: app/code/Paythor/SanalPosPro/etc/crontab.xml
 *
 * Schedules the CaptureInitiatedPayments cron job.
 * Uses Paythor\SanalPosPro\Cron\CaptureInitiatedPayments (NOT the Console Command class)
 * because Magento cron instances must have a public execute() with no arguments.
 *
 * Default schedule: every 15 minutes.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="paythor_sanalpospro_capture_initiated"
             instance="Paythor\SanalPosPro\Cron\CaptureInitiatedPayments"
             method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
    </group>
</config>

