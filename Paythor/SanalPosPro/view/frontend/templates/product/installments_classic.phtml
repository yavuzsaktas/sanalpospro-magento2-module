<?php
/**
 * SanalPosPro Classic Installment Theme — body markup.
 *
 * 1:1 port of WC's templates/installment_theme/classic.php: one outlined
 * card per active family, each card stacks the card image + a 12-row
 * installment table (with '-' placeholders for missing months).
 *
 * @var \Paythor\SanalPosPro\Block\Product\Installments $block
 */

if (!$block->isEnabled()) {
    return;
}

$activeFamilies = $block->getActiveCardFamilies();
if (empty($activeFamilies)) {
    return;
}
?>
<div class="sppro-classic-wrapper" data-sanalpospro-wrapper>
    <div class="sppro-classic-container" data-sanalpospro-container>
        <?php foreach ($activeFamilies as $cardKey):
            $rows = $block->getFamilyRowsAll($cardKey);
        ?>
            <div class="sppro-classic-card" data-sanalpospro-card>
                <table class="sppro-classic-table" data-sanalpospro-table>
                    <thead>
                        <tr>
                            <td colspan="3" class="sppro-classic-card-head">
                                <img src="<?= $block->escapeUrl($block->getCardImageUrl($cardKey)) ?>"
                                     alt="<?= $block->escapeHtmlAttr($cardKey) ?>"
                                     class="sppro-card-image">
                            </td>
                        </tr>
                        <tr>
                            <th><?= $block->escapeHtml(__('Installment')) ?></th>
                            <th><?= $block->escapeHtml(__('Monthly Pay.')) ?></th>
                            <th><?= $block->escapeHtml(__('Total Amount')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($rows as $row):
                            $months = (int)$row['months'];
                            $label  = sprintf(__('%d Installment'), $months);
                        ?>
                            <tr<?= $row['active'] ? '' : ' class="sppro-classic-row-empty"' ?>>
                                <td><?= $block->escapeHtml($label) ?></td>
                                <td><?= $row['active'] ? /* @noEscape */ $row['monthly'] : '-' ?></td>
                                <td><?= $row['active'] ? /* @noEscape */ $row['total']   : '-' ?></td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endforeach; ?>
    </div>

    <div class="sppro-classic-note" data-sanalpospro-note>
        <p><?= $block->escapeHtml(__('Installment amounts are estimated and may vary depending on the bank\'s campaigns and interest rates.')) ?></p>
    </div>
</div>
