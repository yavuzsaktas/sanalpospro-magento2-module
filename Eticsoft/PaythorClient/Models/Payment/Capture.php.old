<?php

namespace Eticsoft\PaythorClient\Models\Payment;

use Eticsoft\PaythorClient\Models\Payment\Instrument\CreditCard;

class Capture
{
    private int $amount;
    private string $currency;
    private array $paymentInstrument;
    private string $family;

    /**
     * @param int $amount Amount to capture (in minor units, e.g. cents/kuruş)
     * @param string $currency Currency code
     * @param array $paymentInstrument Payment instrument details
     * @param string $family Gateway family (e.g. 'creditcard')
     */
    public function __construct(int $amount, string $currency, array $paymentInstrument, string $family = 'creditcard')
    {
        $this->amount = $amount;
        $this->currency = $currency;
        $this->paymentInstrument = $paymentInstrument;
        $this->family = $family;
    }

    public function setAmount(int $amount): self
    {
        $this->amount = $amount;
        return $this;
    }

    public function setCurrency(string $currency): self
    {
        $this->currency = $currency;
        return $this;
    }

    public function setPaymentInstrument(array $paymentInstrument): self
    {
        $this->paymentInstrument = $paymentInstrument;
        return $this;
    }

    public function setFamily(string $family): self
    {
        $this->family = $family;
        return $this;
    }

    public function setCardPayment(CreditCard $creditCard): self
    {
        $this->paymentInstrument = $creditCard->toArray();
        return $this;
    }

    public function toArray(): array
    {
        $data = [
            'capture' => [
                'amount' => $this->amount,
                'currency' => $this->currency,
                'family' => $this->family,
            ]
        ];

        if (!empty($this->paymentInstrument)) {
            $data['capture']['payment_instrument'] = $this->paymentInstrument;
        }

        return $data;
    }
}
